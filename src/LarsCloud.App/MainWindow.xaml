<Window x:Class="LarsCloud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LarsCloud.Controls"
        Title="Lar's Cloud" Width="1220" Height="800" MinWidth="1040" MinHeight="700"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BaseBrush}"
        FontFamily="Segoe UI" WindowStyle="None" ResizeMode="NoResize" BorderThickness="0"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled" RenderOptions.BitmapScalingMode="HighQuality"
        StateChanged="Window_OnStateChanged">
    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="AnimatedPage" TargetType="ScrollViewer">
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style x:Key="WindowCaptionButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CaptionRoot" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CaptionRoot" Property="Background" Value="#29316A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CaptionRoot" Property="Background" Value="#35418D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowCaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CaptionRoot" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CaptionRoot" Property="Background" Value="#E5485D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CaptionRoot" Property="Background" Value="#BE3046"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.Background>
            <RadialGradientBrush Center="0.72,0.12" GradientOrigin="0.72,0.12" RadiusX="0.85" RadiusY="0.85">
                <GradientStop Color="#262D71" Offset="0"/>
                <GradientStop Color="#10142F" Offset="0.46"/>
                <GradientStop Color="#0B0E22" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Border Grid.Row="0" Panel.ZIndex="100" Background="#FA0B0E22" BorderBrush="#392E5DFC" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBarDragArea_OnMouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Image Source="pack://application:,,,/Assets/logo.png" Width="24" Height="24"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Lar’s Cloud" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="9,0,0,0"/>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="MinimizeWindowButton" Content="—" ToolTip="Згорнути" Click="MinimizeWindow_OnClick"
                            Focusable="False" IsTabStop="False"
                            Style="{StaticResource WindowCaptionButton}"/>
                    <Button x:Name="MaximizeWindowButton" Content="□" ToolTip="Розгорнути"
                            Focusable="False" IsTabStop="False"
                            Click="MaximizeWindow_OnClick" Style="{StaticResource WindowCaptionButton}"/>
                    <Button x:Name="CloseWindowButton" Content="×" ToolTip="Згорнути програму в системний трей"
                            Focusable="False" IsTabStop="False"
                            Click="CloseWindow_OnClick" Style="{StaticResource WindowCloseButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Ellipse Grid.Row="1" Width="520" Height="520" Fill="#174838CC" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-260,-180,0">
            <Ellipse.Effect><BlurEffect Radius="45"/></Ellipse.Effect>
        </Ellipse>

        <!-- First-run sign-in -->
        <Grid Grid.Row="1" Visibility="{Binding IsNotAuthenticated, Converter={StaticResource BoolVisibility}}">
            <Border Style="{StaticResource Card}" Width="790" MaxHeight="560" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="52">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="220" Height="220" CornerRadius="48" Background="#111531" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/logo.png" Margin="12" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="44,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Lar’s Cloud" FontSize="42" FontWeight="Bold"/>
                        <TextBlock Text="Ваші файли — під надійним захистом" Foreground="{StaticResource MutedBrush}" FontSize="17" Margin="0,7,0,24"/>
                        <TextBlock Text="Підключіть Google-акаунт. Авторизація відкриється у системному браузері; програма ніколи не бачить і не зберігає ваш пароль." TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,26"/>
                        <Button Content="Зареєструватися через Google" Command="{Binding SignInCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10"/>
                        <Button Content="Увійти через Google" Command="{Binding SignInCommand}" Style="{StaticResource SecondaryButton}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Ellipse Width="8" Height="8" Fill="#2ACE7A" Margin="0,0,8,0"/>
                            <TextBlock Text="Пряме з’єднання з вашим Google Drive" Style="{StaticResource Muted}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Authenticated shell -->
        <Grid Grid.Row="1" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolVisibility}}">
            <Grid.RowDefinitions><RowDefinition Height="76"/><RowDefinition Height="*"/></Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#B20B0E22" BorderBrush="#222E5DFC" BorderThickness="0,0,0,1">
                <Grid Margin="25,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/logo.png" Width="45" Height="45"/>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Lar’s Cloud" FontSize="21" FontWeight="Bold"/>
                            <TextBlock Text="Автоматичне резервне копіювання" Style="{StaticResource Muted}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}" Margin="0,0,10,0">
                            <Ellipse.Effect><DropShadowEffect Color="{Binding StatusBrush.Color}" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                        </Ellipse>
                        <StackPanel>
                            <TextBlock Text="{Binding AccountDisplay}" FontWeight="SemiBold" TextAlignment="Right"/>
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Muted}" TextAlignment="Right"
                                       MaxWidth="390" TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusText}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions><ColumnDefinition Width="230"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Background="#7A10142F" BorderBrush="#222E5DFC" BorderThickness="0,0,1,0">
                    <Grid Margin="18,22">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <StackPanel>
                            <Button Content="⌂  Головна" Command="{Binding ShowDashboardCommand}" Style="{StaticResource NavButton}" Tag="{Binding IsDashboardPage}"/>
                            <Button Content="◷  Історія копій" Command="{Binding ShowHistoryCommand}" Style="{StaticResource NavButton}" Tag="{Binding IsHistoryPage}"/>
                            <Button Content="⚙  Налаштування" Command="{Binding ShowSettingsCommand}" Style="{StaticResource NavButton}" Tag="{Binding IsSettingsPage}"/>
                            <Button Content="↻  Синхронізувати" Command="{Binding SyncNowCommand}" Style="{StaticResource NavButton}" Margin="0,16,0,3"/>
                            <Button Content="▣  Локальні папки" Command="{Binding OpenLocalFolderCommand}" Style="{StaticResource NavButton}"/>
                            <Button Content="☁  Google Drive" Command="{Binding OpenDriveCommand}" Style="{StaticResource NavButton}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2">
                            <Border Background="#251F2759" CornerRadius="12" Padding="13" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Остання копія" Style="{StaticResource Muted}"/>
                                    <TextBlock Text="{Binding LastSync}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding CurrentVersion}" Style="{StaticResource Muted}" HorizontalAlignment="Center"/>
                            <Border Background="#332E5DFC"
                                    BorderBrush="#66536FFF"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="9,7"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding HasAvailableUpdate, Converter={StaticResource BoolVisibility}}">
                                <TextBlock Text="{Binding SidebarUpdateText}"
                                           Foreground="#91A8FF"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dashboard -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource AnimatedPage}"
                              Visibility="{Binding IsDashboardPage, Converter={StaticResource BoolVisibility}}">
                    <StackPanel Margin="26,24,26,34">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="13" Height="13" Fill="{Binding StatusBrush}" Margin="0,4,11,0"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="22" FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Grid Margin="24,16,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Інтернет" Style="{StaticResource Muted}"/><TextBlock Text="Перевірено" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="Остання синхронізація" Style="{StaticResource Muted}"/><TextBlock Text="{Binding LastSync}" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Наступна синхронізація" Style="{StaticResource Muted}"/><TextBlock Text="{Binding NextSync}" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                </Grid>
                                <Grid Margin="24,19,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Синхронізувати кожні" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Width="78" MinWidth="78"
                                                  ItemsSource="{Binding SyncIntervals}"
                                                  SelectedItem="{Binding SyncIntervalDays, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="дн." VerticalAlignment="Center" Margin="9,0,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Синхронізувати зараз" Command="{Binding SyncNowCommand}"
                                            Style="{StaticResource PrimaryButton}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Локальні папки" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="{Binding FolderCountText}" Style="{StaticResource Muted}" Margin="0,-8,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Додати ще одну папку" Command="{Binding AddFolderCommand}"
                                            Style="{StaticResource SuccessButton}" VerticalAlignment="Center"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding SyncFolders}" Margin="0,14,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#65101836" BorderBrush="#292E5DFC" BorderThickness="1"
                                                    CornerRadius="10" Padding="13,10" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"/>
                                                        <TextBlock Text="{Binding Path}" Style="{StaticResource Muted}" Margin="0,3,12,0"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Відкрити"
                                                            Command="{Binding DataContext.OpenSyncFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" Padding="14,7"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Місце на Google Drive" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Text="{Binding DriveUsage}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DriveRemaining}" Style="{StaticResource Muted}" Margin="0,4,0,15"/>
                                    <controls:AnimatedProgressBar AnimatedValue="{Binding DriveUsagePercent}" Foreground="{Binding DriveUsageBrush}" Maximum="100"/>
                                    <Grid Margin="0,8,0,0"><TextBlock Text="0%" Style="{StaticResource Muted}"/><TextBlock Text="{Binding DriveUsagePercent, StringFormat={}{0:0}%}" HorizontalAlignment="Right" Style="{StaticResource Muted}"/></Grid>
                                    <TextBlock Text="{Binding QuotaWarning}" Foreground="#F6B84A" Margin="0,10,0,0"/>
                                    <Button Content="Відкрити папку на Google Drive" Command="{Binding OpenDriveCommand}" Style="{StaticResource SecondaryButton}" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Локальні дані" Style="{StaticResource SectionTitle}"/>
                                        <Button Content="Оновити" Command="{Binding AnalyzeFolderCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Padding="14,7"/>
                                    </Grid>
                                    <Grid Margin="0,9,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Розмір папок" Style="{StaticResource Muted}"/><TextBlock Text="{Binding LocalFolderSize}" Style="{StaticResource MetricValue}"/></StackPanel>
                                        <StackPanel Grid.Column="1"><TextBlock Text="Усього файлів" Style="{StaticResource Muted}"/><TextBlock Text="{Binding LocalFileCount}" Style="{StaticResource MetricValue}"/></StackPanel>
                                    </Grid>
                                    <Grid Margin="0,20,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Нових або змінених" Style="{StaticResource Muted}"/><TextBlock Text="{Binding ChangedFileCount}" FontSize="19" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
                                        <StackPanel Grid.Column="1"><TextBlock Text="До завантаження" Style="{StaticResource Muted}"/><TextBlock Text="{Binding PendingUploadSize}" FontSize="19" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Поточна синхронізація" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Text="{Binding SyncProgressText}" Grid.Column="1" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}"/>
                                </Grid>
                                <controls:AnimatedProgressBar AnimatedValue="{Binding SyncPercent}" Maximum="100" Height="11"/>
                                <Grid Margin="0,11,0,0">
                                    <TextBlock Text="{Binding CurrentFile}" TextTrimming="CharacterEllipsis" MaxWidth="620" HorizontalAlignment="Left"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding SpeedText}" Style="{StaticResource Muted}" Margin="0,0,18,0"/>
                                        <TextBlock Text="{Binding EtaText}" Style="{StaticResource Muted}" Margin="0,0,14,0"/>
                                        <Button Content="Скасувати" Command="{Binding CancelSyncCommand}" Style="{StaticResource SecondaryButton}" Padding="13,6"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Backup history -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource AnimatedPage}"
                              Visibility="{Binding IsHistoryPage, Converter={StaticResource BoolVisibility}}">
                    <StackPanel Margin="32,27,32,40" MaxWidth="960" HorizontalAlignment="Left">
                        <Grid Margin="0,0,0,22">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Історія резервних копій" FontSize="30" FontWeight="Bold"/>
                                <TextBlock Text="Останні синхронізації та результат кожного запуску"
                                           Style="{StaticResource Muted}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Синхронізувати зараз" Command="{Binding SyncNowCommand}"
                                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Margin="14,0,14,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="135"/><ColumnDefinition Width="110"/><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Дата й час" Style="{StaticResource Muted}"/>
                                    <TextBlock Grid.Column="1" Text="Стан" Style="{StaticResource Muted}"/>
                                    <TextBlock Grid.Column="2" Text="Файли" Style="{StaticResource Muted}"/>
                                    <TextBlock Grid.Column="3" Text="Розмір" Style="{StaticResource Muted}"/>
                                    <TextBlock Grid.Column="4" Text="Деталі" Style="{StaticResource Muted}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding History}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#65101836" BorderBrush="#262E5DFC" BorderThickness="1"
                                                    CornerRadius="11" Padding="14" Margin="0,0,0,8" SnapsToDevicePixels="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="135"/><ColumnDefinition Width="110"/><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Date}"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" Margin="0,5,8,0"/>
                                                        <TextBlock Text="{Binding Status}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Files, StringFormat={}{0} файлів}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Size}"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Error}" Foreground="#FF8AA0"
                                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Error}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Settings -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource AnimatedPage}"
                              Visibility="{Binding IsSettingsPage, Converter={StaticResource BoolVisibility}}">
                    <StackPanel Margin="32,27,32,40" MaxWidth="900" HorizontalAlignment="Left">
                        <TextBlock Text="Налаштування" FontSize="30" FontWeight="Bold" Margin="0,0,0,22"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Папки для резервного копіювання" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="{Binding FolderCountText}" Style="{StaticResource Muted}" Margin="0,-8,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Додати ще одну папку" Command="{Binding AddFolderCommand}"
                                            Style="{StaticResource SuccessButton}" VerticalAlignment="Center"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding SyncFolders}" Margin="0,15,0,6">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#65101836" BorderBrush="#292E5DFC" BorderThickness="1"
                                                    CornerRadius="11" Padding="14,11" Margin="0,0,0,9">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Path}" Style="{StaticResource Muted}" Margin="0,3,14,0"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Відкрити" Margin="0,0,9,0" Padding="14,7"
                                                            Command="{Binding DataContext.OpenSyncFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}"/>
                                                    <Button Grid.Column="2" Content="Прибрати" Padding="14,7"
                                                            Command="{Binding DataContext.RemoveSyncFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                            CommandParameter="{Binding}" Style="{StaticResource DangerButton}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Кожна папка зберігається на Google Drive окремо під своєю назвою. Максимум — 10 папок."
                                           Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,13"/>
                                <Button Content="Створити папку Lar’s Cloud на робочому столі" Command="{Binding CreateDesktopFolderCommand}"
                                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Автоматична робота" Style="{StaticResource SectionTitle}"/>
                                <CheckBox Content="Запускати Lar’s Cloud разом із Windows" IsChecked="{Binding AutoStart, Mode=TwoWay}"/>
                                <CheckBox Content="Сповіщати про успішні синхронізації" IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}"/>
                                <CheckBox Content="Сповіщати про помилки" IsChecked="{Binding ErrorNotificationsEnabled, Mode=TwoWay}"/>
                                <CheckBox Content="Видаляти з Google Drive файли, видалені локально" IsChecked="{Binding DeleteRemoteWhenLocalDeleted, Mode=TwoWay}"/>
                                <TextBlock Text="Увага: остання опція за замовчуванням вимкнена. Вона не видаляє локальні файли." Foreground="#F6B84A" Margin="0,7,0,15"/>
                                <Button Content="{Binding PauseButtonText}" Command="{Binding TogglePauseCommand}" Style="{StaticResource DangerButton}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Google-акаунт" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{Binding AccountDisplay}" FontWeight="SemiBold" Margin="0,0,0,14"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Підключити інший акаунт" Command="{Binding SignInCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                                    <Button Content="Вийти з Google-акаунта" Command="{Binding SignOutCommand}" Style="{StaticResource DangerButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Оновлення" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="{Binding CurrentVersion}"/>
                                <TextBlock Text="{Binding UpdateText}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,14"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Перевірити оновлення" Command="{Binding CheckUpdatesCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                                    <Button Content="Завантажити та встановити" Command="{Binding InstallUpdateCommand}" Style="{StaticResource PrimaryButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Журнал і дані" Style="{StaticResource SectionTitle}"/>
                                <WrapPanel>
                                    <Button Content="Відкрити журнал" Command="{Binding OpenLogsCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10"/>
                                    <Button Content="Очистити журнал" Command="{Binding ClearLogsCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10"/>
                                    <Button Content="Очистити службові дані" Command="{Binding ClearServiceDataCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10"/>
                                    <Button Content="Політика конфіденційності" Command="{Binding OpenPrivacyCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,10"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Автор програми: Козак Антон"
                                   Style="{StaticResource Muted}"
                                   FontSize="11"
                                   Opacity="0.72"
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- In-app update prompt -->
        <Grid Grid.RowSpan="2"
              Panel.ZIndex="500"
              Background="#D90B0E22"
              Visibility="{Binding IsUpdatePromptVisible, Converter={StaticResource BoolVisibility}}">
            <Border Style="{StaticResource Card}"
                    Width="560"
                    Padding="30"
                    Background="#F5181C44"
                    BorderBrush="#7A536FFF"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Width="48" Height="48" CornerRadius="14" Background="#2E5DFC" Margin="0,0,15,0">
                            <TextBlock Text="↓" FontSize="25" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Доступна нова версія" FontSize="23" FontWeight="Bold"/>
                            <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="14" Margin="0,4,0,0">
                                <Run Text="Lar’s Cloud "/>
                                <Run Text="{Binding AvailableUpdate.Version, Mode=OneWay}"/>
                                <Run Text=" готовий до встановлення"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Що нового" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#9410142F" CornerRadius="10" Padding="14" Margin="0,0,0,22">
                        <ScrollViewer MaxHeight="145" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding AvailableUpdate.ReleaseNotes}"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Пізніше"
                                Command="{Binding DismissUpdateCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,0"/>
                        <Button Content="Завантажити"
                                Command="{Binding InstallUpdateCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
